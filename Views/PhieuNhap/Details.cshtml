@model MVC.Models.PhieuNhap

@{
    ViewData["Title"] = "Details";
}

<h2>Chi tiết Phiếu Nhập</h2>

<div>
    <h4>Thông tin phiếu</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Ngày nhập
        </dt>
        <dd class="col-sm-10">
            @Model.NgayNhap
        </dd>

        <dt class="col-sm-2">
            Nhà cung cấp
        </dt>
        <dd class="col-sm-10">
            @Model.NhaCungCap?.TenNhaCungCap
        </dd>

        <dt class="col-sm-2">
            Tổng tiền
        </dt>
        <dd class="col-sm-10">
            @Model.TongTien
        </dd>
    </dl>
</div>

<hr />

<h4>Danh sách thiết bị</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Thiết bị</th>
            <th>Số lượng</th>
            <th>Đơn giá</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.ChiTietNhaps != null && Model.ChiTietNhaps.Any())
        {
            foreach (var item in Model.ChiTietNhaps)
            {
                <tr>
                    <td>@item.ThietBi?.TenThietBi</td>
                    <td>@item.SoLuong</td>
                    <td>@item.DonGiaNhap</td>
                    <td>@(item.SoLuong * item.DonGiaNhap)</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center">Không có dữ liệu</td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.PhieuNhapId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>